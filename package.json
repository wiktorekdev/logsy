{
  "name": "@wiktorekdev/logsy",
  "version": "0.2.1",
  "description": "Zero-config, pretty terminal logger for Node.js",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "example": "tsx examples/basic.ts",
    "example:timing": "tsx examples/timing.ts",
    "example:child": "tsx examples/child-loggers.ts",
    "example:context": "tsx examples/context.ts",
    "example:json": "tsx examples/json-output.ts",
    "example:levels": "tsx examples/levels.ts",
    "example:cli": "tsx examples/cli-progress.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "logger",
    "logging",
    "terminal",
    "pretty",
    "colorful",
    "zero-config",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wiktorekdev/logsy.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "npm@10.8.0",

  "devDependencies": {
    "@types/node": "25.3.3",
    "tsx": "4.0.0",
    "typescript": "5.4.0",
    "vitest": "3.0.0"
  }
}
