{
  "name": "@wiktorekdev/logsy",
  "version": "0.2.0",
  "description": "Zero-config, pretty terminal logger for Node.js",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "example": "tsx examples/basic.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "logger",
    "logging",
    "terminal",
    "pretty",
    "colorful",
    "zero-config",
    "typescript"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  }
}
